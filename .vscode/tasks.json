{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe 生成活动文件",
            "command": "C:\\mingw64\\bin\\gcc.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "src/cJSON.c",
                "src/cf_api_get.c",
                "src/parse.c",
                "src/utils.c",
                "src/stats.c",
                "src/html_gen.c",
                "src/batch.c",
                "src/batch_html.c",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe",
                "-Iinclude",
                "-Llib",
                "-lcurl",
                "-lssl",
                "-lcrypto",
                "-lwinmm",
                "-lws2_32",
                "-lwldap32",
                "-lcrypt32"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务。"
        }
    ],
    "version": "2.0.0"
}
